<div class="mx-auto md:w-2/3 w-full max-w-md">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-8 py-10">
    <% if goal.errors.any? %>
      <div class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg" id="error_explanation">
        <p class="mb-2"><%= t(".errors_title") %></p>
        <ul class="list-disc list-inside text-sm">
          <% goal.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h1 class="font-bold text-4xl mb-6"><%= title %></h1>

    <%= form_with model: goal, url: goal_path, class: "contents" do |form| %>
      <div class="my-5">
        <%= form.label :effective_on, t(".effective_on"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :effective_on, required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :target_weight, t(".target_weight"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :target_weight, step: 0.1, min: 0, placeholder: t(".target_weight_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :daily_calorie_target, t(".daily_calorie_target"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :daily_calorie_target, step: 1, min: 0, placeholder: t(".daily_calorie_target_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
        <p class="text-xs text-gray-500 mt-1"><%= t(".target_hint") %></p>
      </div>

      <div class="flex items-center gap-4 mt-6">
        <%= form.submit submit, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
        <%= link_to t(".cancel"), goal_path, class: "text-gray-700 underline hover:no-underline text-sm" %>
      </div>
    <% end %>
  </div>
</div>
