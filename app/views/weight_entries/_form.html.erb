<div class="mx-auto md:w-2/3 w-full max-w-md">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-8 py-10">
    <% if weight_entry.errors.any? %>
      <div class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg" id="error_explanation">
        <p class="mb-2"><%= t("weight_entries.form.errors_title") %></p>
        <ul class="list-disc list-inside text-sm">
          <% weight_entry.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h1 class="font-bold text-4xl mb-6"><%= title %></h1>

    <%= form_with model: weight_entry, class: "contents" do |form| %>
      <div class="my-5">
        <%= form.label :recorded_on, t("weight_entries.form.recorded_on"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :recorded_on, required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :weight, t("weight_entries.form.weight"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :weight, required: true, step: 0.1, min: 0, placeholder: t("weight_entries.form.weight_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :body_fat_percentage, t("weight_entries.form.body_fat_percentage"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :body_fat_percentage, step: 0.1, min: 0, max: 100, placeholder: t("weight_entries.form.body_fat_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
        <p class="text-xs text-gray-500 mt-1"><%= t("weight_entries.form.body_fat_optional") %></p>
      </div>

      <div class="flex items-center gap-4 mt-6">
        <%= form.submit t("weight_entries.form.submit"), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
        <%= link_to t("weight_entries.form.cancel"), weight_entries_path, class: "text-gray-700 underline hover:no-underline text-sm" %>
      </div>
    <% end %>
  </div>
</div>
