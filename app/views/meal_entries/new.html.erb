<div class="mx-auto w-full max-w-3xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-4 py-6 sm:px-8 sm:py-10">
    <% if alert = flash[:alert] %>
      <p class="py-2 px-3 bg-red-50 mb-5 text-red-600 font-medium rounded-lg" id="alert"><%= alert %></p>
    <% end %>

    <% if @entries&.any? { |entry| entry.errors.any? } %>
      <div class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg" id="error_explanation">
        <p class="mb-2"><%= t("meal_entries.form.errors_title") %></p>
        <ul class="list-disc list-inside text-sm">
          <% @entries.each_with_index do |entry, index| %>
            <% entry.errors.full_messages.each do |message| %>
              <li><%= t(".row_error", row: index + 1, message: message) %></li>
            <% end %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h1 class="font-bold text-2xl sm:text-4xl mb-4 sm:mb-6"><%= t(".title") %></h1>

    <%= form_with url: meal_entries_path, scope: :meal_entry_batch, class: "contents",
          data: {
            controller: "meal-entry-rows",
            meal_entry_rows_templates_value: @meal_templates.map { |template|
              { name: template.name, calories: template.calories }
            }.to_json
          } do |form| %>
      <div class="my-5">
        <%= form.label :recorded_on, t("meal_entries.form.recorded_on"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :recorded_on, value: @recorded_on, required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full max-w-xs" %>
      </div>

      <div class="my-5">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
          <h2 class="text-sm font-medium text-gray-700"><%= t(".meals_heading") %></h2>
          <% if @meal_templates.empty? %>
            <%= link_to t(".manage_templates"), meal_templates_path, class: "text-sm text-blue-600 hover:text-blue-500" %>
          <% end %>
        </div>

        <div class="hidden md:grid md:grid-cols-12 md:gap-3 md:px-4 md:pb-2 text-xs font-medium text-gray-500 uppercase tracking-wider">
          <div class="md:col-span-4"><%= t(".name") %></div>
          <div class="md:col-span-3"><%= t("meal_entries.form.meal_type") %></div>
          <div class="md:col-span-2"><%= t(".quantity") %></div>
          <div class="md:col-span-3"><%= t(".calories_per_unit") %></div>
        </div>

        <div class="space-y-3" data-meal-entry-rows-target="rows">
          <% @rows.each_with_index do |row, index| %>
            <div data-meal-entry-rows-target="row" class="rounded-lg border border-gray-200 bg-gray-50 p-4 space-y-3 md:grid md:grid-cols-12 md:gap-3 md:items-end md:space-y-0 md:bg-white md:p-3">
              <div class="md:col-span-4">
                <label class="block text-xs font-medium text-gray-500 mb-1 md:sr-only"><%= t(".name") %></label>
                <%= text_field_tag "meal_entry_batch[rows][][name]", row[:name],
                      list: "meal-template-options",
                      placeholder: t(".name_placeholder"),
                      autocomplete: "off",
                      data: { action: "input->meal-entry-rows#applyTemplate" },
                      class: "block w-full shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 text-sm bg-white" %>
              </div>
              <div class="md:col-span-3">
                <label class="block text-xs font-medium text-gray-500 mb-1 md:sr-only"><%= t("meal_entries.form.meal_type") %></label>
                <%= select_tag "meal_entry_batch[rows][][meal_type]",
                      options_for_select(
                        MealEntry::MEAL_TYPES.map { |type|
                          [ t("meal_entries.meal_types.#{type}"), type ]
                        },
                        row[:meal_type]
                      ),
                      include_blank: t("meal_entries.form.meal_type_optional"),
                      class: "block w-full shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 text-sm bg-white" %>
              </div>
              <div class="grid grid-cols-2 gap-3 md:contents">
                <div class="md:col-span-2">
                  <label class="block text-xs font-medium text-gray-500 mb-1 md:sr-only"><%= t(".quantity") %></label>
                  <%= number_field_tag "meal_entry_batch[rows][][quantity]", row[:quantity].presence || 1,
                        min: 1, step: 1, required: true,
                        data: { meal_entry_rows_target: "quantity" },
                        class: "block w-full shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 text-sm bg-white" %>
                </div>
                <div class="md:col-span-3">
                  <label class="block text-xs font-medium text-gray-500 mb-1 md:sr-only"><%= t(".calories_per_unit") %></label>
                  <%= number_field_tag "meal_entry_batch[rows][][calories]", row[:calories],
                        min: 1, step: 1,
                        placeholder: t(".calories_placeholder"),
                        data: { meal_entry_rows_target: "calories" },
                        class: "block w-full shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 text-sm bg-white" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <datalist id="meal-template-options">
          <% @meal_templates.each do |template| %>
            <option value="<%= template.name %>"></option>
          <% end %>
        </datalist>

        <button type="button" data-action="meal-entry-rows#addRow" class="mt-3 text-sm text-blue-600 hover:text-blue-500 font-medium">
          <%= t(".add_row") %>
        </button>
        <p class="text-xs text-gray-500 mt-2"><%= t(".template_hint") %></p>
      </div>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center gap-3 sm:gap-4 mt-6">
        <%= form.submit t(".submit"), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer w-full sm:w-auto text-center" %>
        <%= link_to t("meal_entries.form.cancel"), meal_entries_path(date: @recorded_on), class: "text-gray-700 underline hover:no-underline text-sm text-center sm:text-left" %>
      </div>
    <% end %>
  </div>
</div>
