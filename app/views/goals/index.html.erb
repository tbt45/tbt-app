<div class="mx-auto w-full max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-4xl"><%= t(".title") %></h1>
    <%= link_to t(".new"), new_goal_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
  </div>

  <% if @goals.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".effective_on") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".target_weight") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".daily_calorie_target") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @goals.each do |goal| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= l(goal.effective_on) %>
                <% if goal == Current.user.current_goal %>
                  <span class="ml-2 text-xs text-blue-600 font-medium"><%= t(".current") %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= goal.target_weight ? t("goals.show.weight_kg", weight: goal.target_weight) : t("common.not_set") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= goal.daily_calorie_target ? t("goals.show.calories_kcal", calories: goal.daily_calorie_target) : t("common.not_set") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-500 bg-white rounded-xl border border-gray-200 px-6 py-10 text-center"><%= t(".empty") %></p>
  <% end %>

  <div class="mt-6">
    <%= link_to t(".back"), goal_path, class: "text-gray-700 underline hover:no-underline text-sm" %>
  </div>
</div>
