<div class="mx-auto md:w-2/3 w-full max-w-lg">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-8 py-10">
    <% if notice = flash[:notice] %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
    <% end %>

    <div class="flex items-center justify-between mb-6">
      <h1 class="font-bold text-4xl"><%= t(".title") %></h1>
      <div class="flex items-center gap-3 text-sm">
        <% if @goal %>
          <%= link_to t(".edit"), edit_goal_path, class: "text-blue-600 hover:text-blue-500 font-medium" %>
          <%= link_to t(".new"), new_goal_path, class: "text-blue-600 hover:text-blue-500 font-medium" %>
        <% end %>
        <%= link_to t(".history"), goals_path, class: "text-gray-600 hover:text-gray-900 font-medium" %>
      </div>
    </div>

    <% if @goal %>
      <dl class="space-y-4">
        <div>
          <dt class="text-sm text-gray-500"><%= t(".effective_on") %></dt>
          <dd class="text-lg font-medium text-gray-900 mt-1"><%= l(@goal.effective_on) %></dd>
        </div>

        <div>
          <dt class="text-sm text-gray-500"><%= t(".target_weight") %></dt>
          <dd class="text-lg font-medium text-gray-900 mt-1">
            <% if @goal.target_weight %>
              <%= t(".weight_kg", weight: @goal.target_weight) %>
            <% else %>
              <span class="text-gray-400"><%= t(".not_set") %></span>
            <% end %>
          </dd>
        </div>

        <div>
          <dt class="text-sm text-gray-500"><%= t(".daily_calorie_target") %></dt>
          <dd class="text-lg font-medium text-gray-900 mt-1">
            <% if @goal.daily_calorie_target %>
              <%= t(".calories_kcal", calories: @goal.daily_calorie_target) %>
            <% else %>
              <span class="text-gray-400"><%= t(".not_set") %></span>
            <% end %>
          </dd>
        </div>

        <% user = Current.user %>
        <% if user.latest_weight_entry %>
          <div class="pt-4 border-t border-gray-100">
            <dt class="text-sm text-gray-500"><%= t(".latest_weight") %></dt>
            <dd class="text-lg font-medium text-gray-900 mt-1">
              <%= t(".weight_kg", weight: user.latest_weight_entry.weight) %>
              <span class="text-sm text-gray-500 font-normal">
                （<%= l(user.latest_weight_entry.recorded_on) %>）
              </span>
            </dd>

            <% if user.weight_gap_to_target %>
              <% gap = user.weight_gap_to_target %>
              <p class="text-sm mt-2 <%= gap.positive? ? "text-amber-600" : "text-green-600" %>">
                <%= t(".weight_gap", gap: gap.abs, direction: gap.positive? ? t(".over") : t(".under")) %>
              </p>
            <% end %>
          </div>
        <% end %>
      </dl>
    <% else %>
      <p class="text-gray-500 mb-6"><%= t(".empty") %></p>
      <%= link_to t(".new"), new_goal_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
    <% end %>
  </div>
</div>
