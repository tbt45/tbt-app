<div class="mx-auto md:w-2/3 w-full max-w-md">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-4 py-6 sm:px-8 sm:py-10">
    <% if exercise_entry.errors.any? %>
      <div class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg" id="error_explanation">
        <p class="mb-2"><%= t("exercise_entries.form.errors_title") %></p>
        <ul class="list-disc list-inside text-sm">
          <% exercise_entry.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h1 class="font-bold text-2xl sm:text-4xl mb-4 sm:mb-6"><%= title %></h1>

    <%= form_with model: exercise_entry, class: "contents" do |form| %>
      <div class="my-5">
        <%= form.label :recorded_on, t("exercise_entries.form.recorded_on"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :recorded_on, required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :name, t("exercise_entries.form.name"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, required: true, placeholder: t("exercise_entries.form.name_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :calories_burned, t("exercise_entries.form.calories_burned"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :calories_burned, required: true, step: 1, min: 1, placeholder: t("exercise_entries.form.calories_burned_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :duration_minutes, t("exercise_entries.form.duration_minutes"), class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :duration_minutes, step: 1, min: 1, placeholder: t("exercise_entries.form.duration_minutes_placeholder"), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
        <p class="text-xs text-gray-500 mt-1"><%= t("exercise_entries.form.duration_minutes_optional") %></p>
      </div>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center gap-3 sm:gap-4 mt-6">
        <%= form.submit t("exercise_entries.form.submit"), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer w-full sm:w-auto text-center" %>
        <%= link_to t("exercise_entries.form.cancel"), exercise_entries_path(date: exercise_entry.recorded_on || Date.current), class: "text-gray-700 underline hover:no-underline text-sm text-center sm:text-left" %>
      </div>
    <% end %>
  </div>
</div>
