<div class="mx-auto w-full max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-4xl"><%= t(".title") %></h1>
    <%= link_to t(".new"), new_weight_entry_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
  </div>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <% if @weight_entries.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".recorded_on") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".weight") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".body_fat_percentage") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".actions") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @weight_entries.each do |entry| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= l(entry.recorded_on) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= t("goals.show.weight_kg", weight: entry.weight) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if entry.body_fat_percentage %>
                  <%= t(".body_fat_percent", value: entry.body_fat_percentage) %>
                <% else %>
                  <%= t("common.not_set") %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-3">
                <%= link_to t(".edit"), edit_weight_entry_path(entry), class: "text-blue-600 hover:text-blue-500" %>
                <%= button_to t(".delete"), weight_entry_path(entry), method: :delete, form: { data: { turbo_confirm: t(".confirm_delete") } }, class: "inline text-red-600 hover:text-red-500 cursor-pointer" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-500 bg-white rounded-xl border border-gray-200 px-6 py-10 text-center"><%= t(".empty") %></p>
  <% end %>
</div>
